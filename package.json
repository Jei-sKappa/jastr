{
  "name": "jastr-workspace",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run build:engine && bun run build:cli",
    "build:engine": "cd packages/engine && bun run build",
    "build:cli": "cd packages/cli && bun run build",
    "check": "biome check .",
    "docs:cli:living": "tsx packages/cli/scripts/generate-living-docs.ts",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:cli:e2e": "vitest run packages/cli/test/e2e",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/node": "^25.9.1",
    "execa": "^9.6.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
