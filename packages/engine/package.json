{
  "name": "@jastr/engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && bun build src/index.ts --target=node --format=esm --outdir=dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "remark-directive": "^4.0.0",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "yaml": "^2.9.0"
  }
}
